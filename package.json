{
  "name": "phil",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run build:sw && next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "type-check": "tsc --noEmit",
    "prepare": "husky",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --linked > types/database.ts",
    "verify:rls": "tsx scripts/verify-rls.ts",
    "build:sw": "esbuild app/sw.ts --bundle --minify --outfile=public/sw.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@react-email/components": "^1.0.12",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^1.23.0",
    "next": "16.2.2",
    "radix-ui": "^1.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "resend": "^6.16.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "serwist": "^9.5.11",
    "sharp": "^0.35.3",
    "supabase": "^2.109.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.5",
    "typescript": "^5"
  }
}
