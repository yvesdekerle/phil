{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpm --version:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(rm:*)",
      "Bash(rsync:*)",
      "Bash(which:*)",
      "Read(**/*.ts)",
      "Read(**/*.tsx)",
      "Read(**/*.js)",
      "Read(**/*.mjs)",
      "Read(**/*.css)",
      "Read(**/*.json)",
      "Read(**/*.sql)",
      "Read(**/*.md)",
      "Read(**/*.csv)",
      "Read(**/*.yaml)",
      "Read(**/*.yml)",
      "Read(**/.gitignore)",
      "Read(**/.env.example)",
      "Read(/tmp/**)",
      "Edit(./app/**)",
      "Edit(./components/**)",
      "Edit(./lib/**)",
      "Edit(./types/**)",
      "Edit(./supabase/**)",
      "Edit(./biome.json)",
      "Edit(./tsconfig.json)",
      "Edit(./next.config.ts)",
      "Edit(./postcss.config.mjs)",
      "Edit(./package.json)",
      "Edit(./.gitignore)",
      "Edit(./.env.example)",
      "Edit(./CLAUDE.md)",
      "Edit(./.husky/**)",
      "Edit(./.github/**)",
