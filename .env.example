# ============================================================
# Phil — variables d'environnement
# Copier en .env.local pour le dev local (jamais commité).
# Les valeurs réelles vivent dans Vercel (Settings → Environment Variables)
# pour les trois environnements : production, preview, development.
# ============================================================

# --- Supabase (PHIL-A03) ---
# Dashboard : https://supabase.com/dashboard/project/xinbuahgscaydpkcamsl
NEXT_PUBLIC_SUPABASE_URL=           # https://xinbuahgscaydpkcamsl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # Clé anon publique (protégée par RLS)
SUPABASE_SERVICE_ROLE_KEY=          # Server only — bypasse RLS, JAMAIS côté client

# --- Application ---
NEXT_PUBLIC_APP_URL=                # Prod : https://phil-phi-nine.vercel.app — dev : http://localhost:3000

# --- Google OAuth ---
# Rien ici : le client ID/secret Google sont configurés dans Supabase
# (Authentication → Sign In / Providers → Google), pas dans l'application.

# --- Email Resend (Phase 7, PHIL-K01) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=                  # onboarding@resend.dev en dev, domaine vérifié ensuite

# --- Rate limiting Upstash (optionnel, PHIL-J02) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
